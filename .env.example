# Groq API (free tier — https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# NewsAPI (free tier — https://newsapi.org)
# Optional: Falls back to free Google News RSS if not set
NEWS_API_KEY=your_newsapi_key_here

# Optional: Cache TTL for build_cache.py
# CACHE_TTL_HOURS=24
